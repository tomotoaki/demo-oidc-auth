{
  "realm": "demo",
  "enabled": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "ssoSessionIdleTimeout": 300,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 60,
  "refreshTokenMaxReuse": 0,
  "revokeRefreshToken": false,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "管理者ロール - スイッチユーザー権限を持つ"
      },
      {
        "name": "USER",
        "description": "一般ユーザーロール"
      }
    ]
  },
  "clients": [
    {
      "clientId": "demo-oidc-auth-client-bff",
      "name": "demo-oidc-auth-client-bff",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "demo-oidc-auth-client-bff-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:8080/api/v2/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:5173"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173",
        "standard.token.exchange.enabled": "true"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "demo-oidc-auth-mobile-bff",
      "name": "demo-oidc-auth-mobile-bff",
      "description": "Spring Boot BFF for smartphone/tablet app access",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "demo-oidc-auth-mobile-bff-secret",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:8081/mobile-bff/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:8081"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8081/mobile-bff/*",
        "standard.token.exchange.enabled": "true"
      },
      "protocolMappers": [
        {
          "name": "audience-demo-oidc-auth-server",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "demo-oidc-auth-server",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "demo-oidc-auth-server",
      "name": "demo-oidc-auth-server",
      "description": "Audience client for the resource server API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "attributes": {
        "standard.token.exchange.enabled": "true"
      }
    }
  ],
  "users": [
    {
      "username": "demo",
      "email": "demo@example.com",
      "firstName": "Demo",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"]
    },
    {
      "username": "admin",
      "email": "admin@example.com",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["ADMIN"]
    }
  ]
}
